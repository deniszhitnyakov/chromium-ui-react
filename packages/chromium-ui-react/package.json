{
  "name": "chromium-ui-react",
  "version": "0.4.2",
  "description": "Chromium-native React component library. Build browser extensions, Electron apps, and Google-adjacent web UIs that look and feel like first-party Chromium surfaces.",
  "type": "module",
  "main": "./dist/chromium-ui-react.cjs",
  "module": "./dist/chromium-ui-react.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/chromium-ui-react.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chromium-ui-react.js",
      "require": "./dist/chromium-ui-react.cjs"
    },
    "./styles.css": "./dist/chromium-ui-react.css",
    "./tokens.css": "./src/styles/tokens.css"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0"
  },
  "keywords": [
    "react",
    "react-components",
    "chromium",
    "chrome",
    "chrome-extension",
    "chrome-extensions",
    "manifest-v3",
    "ui",
    "ui-library",
    "ui-components",
    "component-library",
    "design-system",
    "cr-elements",
    "google",
    "material",
    "dark-mode",
    "typescript",
    "css-variables",
    "css-in-js-free",
    "ssr",
    "tree-shakeable"
  ],
  "author": {
    "name": "Denis Zhitnyakov",
    "email": "denis.zhitnyakov@gmail.com",
    "url": "https://github.com/ztnkv"
  },
  "license": "MIT",
  "homepage": "https://ztnkv.github.io/chromium-ui-react/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ztnkv/chromium-ui-react.git",
    "directory": "packages/chromium-ui-react"
  },
  "bugs": {
    "url": "https://github.com/ztnkv/chromium-ui-react/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
